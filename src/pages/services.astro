---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Conciergerie de Luxe à Genève | Services Premium | Swiss Prestige" description="Service de conciergerie de luxe à Genève. Sélection, livraison premium et gestion de collections privées de produits de prestige en Suisse.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="t-label">Conciergerie de luxe</div>
      <h1 class="hero__title">Services</h1>
      <p class="hero__subtitle">Sélection, conciergerie et livraison premium en Suisse</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works">
    <div class="how-it-works__inner">
      <div class="how-it-works__header">
        <div class="t-label">Comment ça fonctionne</div>
        <h2 class="t-section">Simple.<br/>Exclusif.</h2>
        <div class="divider-gold"></div>
      </div>

      <div class="steps">
        <div class="step">
          <div class="step__number">01</div>
          <h3 class="step__title">Sélectionnez</h3>
          <p class="step__text">Parcourez nos collections — vodka Hoverla, cigares Mont Noir, et les nouvelles références que notre équipe ajoute régulièrement. Votre conseiller peut aussi vous guider selon vos goûts.</p>
        </div>
        <div class="step">
          <div class="step__number">02</div>
          <h3 class="step__title">Commandez</h3>
          <p class="step__text">Par téléphone, par message, ou bientôt depuis notre application mobile. Un conseiller dédié traite chaque commande personnellement.</p>
        </div>
        <div class="step">
          <div class="step__number">03</div>
          <h3 class="step__title">Recevez</h3>
          <p class="step__text">Livraison soignée à votre porte, partout en Suisse. Emballage premium, délais respectés, discrétion garantie.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONCIERGERIE -->
  <section class="conciergerie">
    <div class="conciergerie__inner">
      <div class="conciergerie__text">
        <div class="t-label">Service premium</div>
        <h2 class="conciergerie__heading">Conciergerie<br/>personnalisée</h2>
        <div class="divider-gold"></div>
        <p class="t-body">Votre conseiller personnel apprend vos préférences au fil du temps. Il vous informe des nouveautés pertinentes, vous réserve les éditions limitées en avance, et coordonne chaque détail de vos commandes — de la sélection à la livraison.</p>
        <ul class="conciergerie__list">
          <li>Conseiller dédié et disponible</li>
          <li>Accès prioritaire aux éditions limitées</li>
          <li>Recommandations personnalisées</li>
          <li>Livraison express dans toute la Suisse</li>
          <li>Emballage cadeau premium</li>
        </ul>
      </div>
      <div class="conciergerie__image">
        <img src="/images/vodka/hoverla-scene.jpg" alt="Verres Hoverla — service de conciergerie Swiss Prestige" />
      </div>
    </div>
  </section>

  <!-- APP -->
  <section class="app-section">
    <div class="app-section__inner">
      <div class="app-section__visual">
        <div class="app-section__phone">
          <img src="/images/brand/SP_crown_gold_transparent.svg" alt="Swiss Prestige — application mobile de conciergerie" class="app-section__icon" />
          <div class="app-section__phone-label">Bientôt disponible</div>
        </div>
      </div>
      <div class="app-section__text">
        <div class="t-label">Application mobile</div>
        <h2 class="app-section__heading">Swiss Prestige<br/>dans votre poche</h2>
        <div class="divider-gold"></div>
        <p class="t-body">Commandez vos produits favoris, suivez vos livraisons en temps réel, découvrez nos nouvelles sélections et gérez vos préférences — directement depuis votre smartphone. L'intégralité du service Swiss Prestige, accessible à tout moment.</p>
        <div class="app-section__features">
          <div class="app-feature">
            <span class="app-feature__dot"></span>
            <span>Commande en un geste</span>
          </div>
          <div class="app-feature">
            <span class="app-feature__dot"></span>
            <span>Suivi en temps réel</span>
          </div>
          <div class="app-feature">
            <span class="app-feature__dot"></span>
            <span>Notifications exclusives</span>
          </div>
          <div class="app-feature">
            <span class="app-feature__dot"></span>
            <span>Profil de préférences</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CORPORATE -->
  <section class="corporate">
    <div class="corporate__inner">
      <div class="corporate__header">
        <div class="t-label">B2B & Événements</div>
        <h2 class="t-section">Corporate<br/>& événements</h2>
        <div class="divider-gold"></div>
        <p class="t-body" style="max-width:700px;">Swiss Prestige accompagne les entreprises dans la sélection de produits de prestige pour leurs événements, séminaires et relations clients. Coffrets sur mesure, dégustations animées, prestations clés en main.</p>
      </div>

      <div class="corporate__grid">
        <div class="corporate-card">
          <h3 class="corporate-card__title">Événements privés</h3>
          <p class="corporate-card__text">Dégustations guidées, soirées thématiques, lancements de produits. Nous concevons et animons des expériences sur mesure pour vos invités.</p>
        </div>
        <div class="corporate-card">
          <h3 class="corporate-card__title">Cadeaux d'affaires</h3>
          <p class="corporate-card__text">Coffrets personnalisés aux couleurs de votre entreprise, éditions limitées, packaging premium. Un cadeau qui marque les esprits.</p>
        </div>
        <div class="corporate-card">
          <h3 class="corporate-card__title">Collections privées</h3>
          <p class="corporate-card__text">Constitution et gestion de caves à cigares et collections de spiritueux. Sourcing de pièces rares, stockage en conditions optimales, conseil d'experts.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta">
    <div class="services-cta__bg"></div>
    <div class="services-cta__content">
      <h2 class="services-cta__title">Parlons de<br/>votre projet</h2>
      <p class="t-body" style="text-align:center; max-width:500px; margin:0 auto 40px;">Commande personnelle, événement d'entreprise ou collection privée — contactez notre équipe pour en discuter.</p>
      <a href="/contact" class="btn-primary">Nous contacter</a>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/scenes/bg-bar-night.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.25);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8,8,8,0.1) 0%, rgba(8,8,8,0.7) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: left;
    padding: 0 var(--pad-x) 80px;
    max-width: var(--container-xl);
    width: 100%;
    margin: 0 auto;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(56px, 8vw, 100px);
    line-height: 0.95;
    color: var(--white);
    margin: 16px 0;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-60);
  }

  /* HOW IT WORKS */
  .how-it-works {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black);
  }

  .how-it-works__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .how-it-works__header {
    margin-bottom: 80px;
    max-width: 600px;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }

  .step {
    padding: 40px 0;
    border-top: 1px solid var(--gold-dim);
  }

  .step__number {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .step__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 3vw, 48px);
    font-weight: 300;
    color: var(--white);
    margin-bottom: 16px;
  }

  .step__text {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--white-40);
  }

  /* CONCIERGERIE */
  .conciergerie {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black-warm);
  }

  .conciergerie__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .conciergerie__text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .conciergerie__heading {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--white);
  }

  .conciergerie__list {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .conciergerie__list li {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    color: var(--white-60);
    padding-left: 20px;
    position: relative;
  }

  .conciergerie__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 1px;
    background: var(--gold);
  }

  .conciergerie__image {
    overflow: hidden;
  }

  .conciergerie__image img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  /* APP SECTION */
  .app-section {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black);
    border-top: 1px solid var(--border);
  }

  .app-section__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .app-section__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .app-section__phone {
    width: 280px;
    height: 480px;
    border: 1px solid var(--gold-dim);
    background: linear-gradient(180deg, rgba(200,168,78,0.04) 0%, rgba(200,168,78,0.01) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }

  .app-section__icon {
    width: 80px;
    height: auto;
    opacity: 0.5;
  }

  .app-section__phone-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.6;
  }

  .app-section__text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .app-section__heading {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--white);
  }

  .app-section__features {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 12px;
  }

  .app-feature {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    color: var(--white-60);
  }

  .app-feature__dot {
    width: 6px;
    height: 6px;
    background: var(--gold);
    flex-shrink: 0;
  }

  /* CORPORATE */
  .corporate {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black-warm);
  }

  .corporate__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .corporate__header {
    margin-bottom: 80px;
  }

  .corporate__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .corporate-card {
    padding: 40px;
    border: 1px solid var(--border);
    transition: border-color 0.3s ease;
  }

  .corporate-card:hover {
    border-color: var(--gold-dim);
  }

  .corporate-card__title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 300;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .corporate-card__text {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--white-40);
  }

  /* CTA */
  .services-cta {
    position: relative;
    padding: var(--section-lg) var(--pad-x);
    overflow: hidden;
  }

  .services-cta__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/scenes/bg-mountain.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.2);
  }

  .services-cta__content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .services-cta__title {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 88px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 24px;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .steps {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .conciergerie__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .conciergerie__image img {
      height: 360px;
    }

    .app-section__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .app-section__visual {
      order: 2;
    }

    .app-section__phone {
      width: 200px;
      height: 340px;
    }

    .corporate__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
