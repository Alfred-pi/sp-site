---
import Layout from '../layouts/Layout.astro';

const variants = [
  { name: "Original", desc: "La pureté absolue. Eau de source des Carpates et blé ukrainien.", img: "/images/vodka/hoverla-official-1.jpg" },
  { name: "Honey", desc: "Miel de fleurs sauvages des montagnes. Douceur et caractère.", img: "/images/vodka/hoverla-official-2.jpg" },
  { name: "Birch", desc: "Sève de bouleau infusée. Fraîcheur minérale unique.", img: "/images/vodka/hoverla-official-3.jpg" },
  { name: "Pepper", desc: "Piment rouge des Carpates. Chaleur et intensité.", img: "/images/vodka/hoverla-official-4.jpg" },
  { name: "Cranberry", desc: "Canneberges sauvages cueillies à maturité. Fruité et vif.", img: "/images/vodka/hoverla-official-5.jpg" },
  { name: "Herbal", desc: "Herbes aromatiques des prairies d'altitude. Complexe et subtil.", img: "/images/vodka/hoverla-official-6.jpg" },
  { name: "Lemon", desc: "Zestes de citron frais. Vivacité et élégance.", img: "/images/vodka/hoverla-official-7.jpg" },
];
---

<Layout title="Vodka Hoverla | Vodka Artisanale des Carpates | Swiss Prestige" description="Découvrez Hoverla, vodka artisanale ukrainienne élaborée avec l'eau pure des Carpates. Sept saveurs d'exception, distribuées exclusivement par Swiss Prestige en Suisse.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="t-label">Vodka artisanale ukrainienne</div>
      <h1 class="hero__title">Hoverla</h1>
      <p class="hero__subtitle">Distillée à 2 061 mètres d'altitude. Sept saveurs.</p>
    </div>
  </section>

  <!-- STORY -->
  <section class="story">
    <div class="story__inner">
      <div class="story__text">
        <div class="t-label">L'histoire</div>
        <h2 class="story__heading">L'eau pure<br/>des Carpates</h2>
        <div class="divider-gold"></div>
        <p class="t-body">L'eau de source traverse la roche des Carpates depuis des millénaires avant d'atteindre la distillerie. Le blé est cultivé en altitude, dans un sol que l'industrie n'a jamais touché. C'est cette combinaison qui donne à Hoverla sa pureté — nette, minérale, immédiate.</p>
        <p class="t-body">Chaque bouteille est distillée en petits lots. Sept infusions différentes — du classique au miel de montagne, en passant par la sève de bouleau — qui explorent chacune un aspect de ce terroir unique. Hoverla porte le nom du plus haut sommet d'Ukraine. Ce n'est pas un hasard.</p>
      </div>
      <div class="story__image">
        <img src="/images/vodka/hoverla-official-1.jpg" alt="Bouteille Hoverla Original — vodka artisanale premium des Carpates" />
      </div>
    </div>
  </section>

  <!-- VARIANTS GRID -->
  <section class="variants">
    <div class="variants__inner">
      <div class="variants__header">
        <div class="t-label">La collection</div>
        <h2 class="t-section">Sept caractères</h2>
        <div class="divider-gold"></div>
      </div>

      <div class="variants__grid">
        {variants.map((v) => (
          <div class="variant-card">
            <div class="variant-card__image">
              <img src={v.img} alt={`Vodka Hoverla ${v.name} — saveur artisanale premium`} />
            </div>
            <div class="variant-card__info">
              <h3 class="variant-card__name">{v.name}</h3>
              <p class="variant-card__desc">{v.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LINEUP -->
  <section class="lineup">
    <div class="lineup__inner">
      <img src="/images/vodka/hoverla-scene.jpg" alt="Verres Hoverla Premium Vodka — dégustation" class="lineup__img" />
    </div>
  </section>

  <!-- CTA -->
  <section class="vodka-cta">
    <div class="vodka-cta__inner">
      <h2 class="vodka-cta__title">Commander Hoverla</h2>
      <p class="t-body" style="text-align:center; max-width:500px; margin:0 auto 40px;">Distribuée exclusivement par Swiss Prestige en Suisse. Contactez notre équipe pour choisir vos saveurs.</p>
      <a href="/contact" class="btn-primary">Passer commande</a>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/scenes/hoverla-mountain.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.3);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8,8,8,0.1) 0%, rgba(8,8,8,0.7) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: left;
    padding: 0 var(--pad-x) 80px;
    max-width: var(--container-xl);
    width: 100%;
    margin: 0 auto;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(56px, 8vw, 100px);
    line-height: 0.95;
    color: var(--white);
    margin: 16px 0;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-60);
  }

  /* STORY */
  .story {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black);
  }

  .story__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .story__text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .story__heading {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--white);
  }

  .story__image {
    overflow: hidden;
  }

  .story__image img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  /* VARIANTS */
  .variants {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black-warm);
  }

  .variants__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .variants__header {
    margin-bottom: 80px;
    max-width: 600px;
  }

  .variants__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
  }

  .variant-card {
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .variant-card:hover {
    border-color: var(--gold-dim);
  }

  .variant-card__image {
    overflow: hidden;
    height: 320px;
    background: #0D0A06;
  }

  .variant-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .variant-card:hover .variant-card__image img {
    transform: scale(1.05);
  }

  .variant-card__info {
    padding: 24px;
  }

  .variant-card__name {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 300;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .variant-card__desc {
    font-size: 13px;
    font-weight: 300;
    color: var(--white-40);
    line-height: 1.6;
  }

  /* LINEUP */
  .lineup {
    padding: 0;
    background: var(--black);
  }

  .lineup__inner {
    max-width: 100%;
  }

  .lineup__img {
    width: 100%;
    height: 500px;
    object-fit: cover;
  }

  /* CTA */
  .vodka-cta {
    padding: var(--section-lg) var(--pad-x);
    background: var(--black);
    text-align: center;
  }

  .vodka-cta__inner {
    max-width: var(--container-lg);
    margin: 0 auto;
  }

  .vodka-cta__title {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 300;
    color: var(--white);
    margin-bottom: 24px;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .story__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .story__image img {
      height: 360px;
    }

    .variants__grid {
      grid-template-columns: 1fr;
    }

    .variant-card__image {
      height: 260px;
    }

    .lineup__img {
      height: 300px;
    }
  }
</style>
