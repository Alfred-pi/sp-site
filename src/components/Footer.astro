---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__divider"></div>

  <div class="footer__container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <img src="/images/brand/SP_center_dark_transparent.svg" alt="Swiss Prestige" class="footer__logo-img" />
        <p class="footer__tagline">Produits de luxe et conciergerie premium, depuis Genève</p>
      </div>

      <!-- Navigation -->
      <div class="footer__col">
        <h4 class="footer__title">Navigation</h4>
        <ul class="footer__links">
          <li><a href="/">Accueil</a></li>
          <li><a href="/vodka">Vodka Hoverla</a></li>
          <li><a href="/cigares">Cigares Mont Noir</a></li>
          <li><a href="/services">Services</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="footer__col">
        <h4 class="footer__title">Services</h4>
        <ul class="footer__links">
          <li><a href="/services">Conciergerie premium</a></li>
          <li><a href="/services">Collections privées</a></li>
          <li><a href="/services">Événements corporate</a></li>
          <li><a href="/contact">Nous contacter</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer__col">
        <h4 class="footer__title">Contact</h4>
        <ul class="footer__links">
          <li>Genève, Suisse</li>
          <li><a href="mailto:contact@swiss-prestige.ch">contact@swiss-prestige.ch</a></li>
          <li><a href="https://instagram.com/swissprestige" target="_blank" rel="noopener">Instagram</a></li>
        </ul>
      </div>
    </div>

    <!-- Legal -->
    <div class="footer__legal">
      <p>L'abus d'alcool est dangereux pour la santé. À consommer avec modération.</p>
      <p>&copy; {currentYear} Swiss Prestige. Tous droits réservés. Genève, Suisse.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--black);
    color: var(--white-60);
    padding: 0 0 40px;
  }

  .footer__divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin-bottom: 80px;
  }

  .footer__container {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 40px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
  }

  .footer__brand {
    max-width: 320px;
  }

  .footer__logo-img {
    height: 96px;
    width: auto;
    margin-bottom: 20px;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    color: var(--white-40);
  }

  .footer__title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li {
    margin-bottom: 12px;
    font-size: 14px;
    font-weight: 300;
    color: var(--white-40);
  }

  .footer__links a {
    color: var(--white-40);
    transition: color 0.3s ease;
  }

  .footer__links a:hover {
    color: var(--gold);
  }

  .footer__legal {
    padding-top: 40px;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer__legal p {
    font-size: 11px;
    font-weight: 300;
    color: var(--white-20);
    margin-bottom: 8px;
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 0 0 32px;
    }

    .footer__container {
      padding: 0 24px;
    }

    .footer__divider {
      margin-bottom: 60px;
    }

    .footer__grid {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-bottom: 40px;
    }

    .footer__logo-img {
      height: 72px;
    }
  }
</style>
